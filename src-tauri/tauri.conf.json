{
  "productName": "dota2-scripts",
  "version": "0.1.0",
  "identifier": "com.dota2scripts.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-ui/dist",
    "beforeDevCommand": "cd src-ui && npx vite",
    "beforeBuildCommand": "cd src-ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Dota 2 Script Automation",
        "width": 1024,
        "height": 700,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
